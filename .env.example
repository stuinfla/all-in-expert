# All-In Expert - Environment Variables
# Copy this to .env and fill in your keys

# Claude API key (for LLM-powered query synthesis)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# AssemblyAI API key (optional - for speaker diarization)
# Get from: https://www.assemblyai.com/app/account
# Cost: ~$0.17/hr of audio (~$51 for full podcast catalog)
ASSEMBLYAI_API_KEY=
